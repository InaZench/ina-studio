---
import Layout from "../layouts/Layout.astro";


const selectedWork = [
  {
    title: "L'Empreinte",
    client: "MAISON AURÉLIEN — 2026",
    slug: "lempreinte",
  },
  {
    title: "Aura Noir",
    client: "STILL LIFE — 2026",
    slug: "aura-noir",
  },
  {
    title: "The Nomad",
    client: "CAMPAIGN — 2025",
    slug: "the-nomad",
  },
  {
    title: "Maison Norden",
    client: "NORDEN SKINCARE — 2025",
    slug: "maison-norden",
  },
];
---

<Layout title="INA — Visual stories for brands">
<section class="relative w-screen h-screen overflow-hidden bg-[#0E0E0E]">
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover opacity-60" style="z-index:0;" preload="auto"
  >
    <source src="/0607.mp4" type="video/mp4" />
  </video>
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a1a1a] via-[#0E0E0E] to-[#000000]"></div>

    <div class="relative z-10 flex flex-col justify-end h-full px-6 md:px-10 pb-16 md:pb-20 text-white">
      <p class="text-[10px] md:text-[11px] font-light tracking-[0.3em] uppercase text-white/60 mb-5">
        Showreel · 2026
      </p>
      <h1 class="font-serif font-light leading-[1.05] text-[42px] md:text-[88px] max-w-4xl">
        Visual stories<br />for brands.
      </h1>
      <p class="font-serif text-[18px] md:text-[24px] font-light text-white/70 mt-6 max-w-xl">
        Cinematic content crafted with AI.
      </p>
    </div>

    <div class="absolute bottom-6 right-6 md:bottom-8 md:right-10 text-[10px] font-light tracking-[0.3em] uppercase text-white/50">
      Scroll ↓
    </div>
  </section>

  <section class="bg-[#FAFAF7] px-6 md:px-10 pt-32 md:pt-44 pb-32 md:pb-44">
    <div class="max-w-[1280px] mx-auto">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase text-center mb-10">
        Selected Work
      </p>
      <h2 class="font-serif italic font-light text-[36px] md:text-[48px] text-[#0A0A0A] text-center mb-20 md:mb-28">
        A selection of recent projects.
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
        {selectedWork.map((project, i) => (
          <a
            href={`/work/${project.slug}`}
            class={`group block ${i % 2 === 1 ? "md:mt-32" : ""}`}
          >
            <div
              class={`bg-[#1A1A1A] overflow-hidden mb-6 transition-transform duration-700 group-hover:scale-[1.02] ${
                i % 2 === 0 ? "aspect-[16/10]" : "aspect-[3/4]"
              }`}
            ></div>
            <h3 class="font-serif text-[24px] md:text-[26px] font-normal text-[#0A0A0A] leading-tight">
              {project.title}
            </h3>
            <p class="mt-2 text-[11px] font-light tracking-[0.05em] text-[#888888] uppercase">
              {project.client}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[#F4F4F1] px-6 md:px-10 py-32 md:py-44">
    <div class="max-w-[880px] mx-auto text-center">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-10">
        Approach
      </p>
      <h2 class="font-serif font-light text-[32px] md:text-[44px] text-[#0A0A0A] leading-tight mb-12">
        Cinematic content,<br />crafted with AI.
      </h2>
      <p class="font-sans text-[15px] md:text-[16px] font-light text-[#555555] leading-relaxed max-w-[560px] mx-auto">
        Solo creator working with European brands across luxury, fashion, and product.
        Every frame is built through a deliberate pipeline — concept first, AI as craft tool, editorial finish.
      </p>
    </div>
  </section>

  <section class="bg-[#0A0A0A] px-6 md:px-10 py-28 md:py-32 min-h-[480px] flex flex-col items-center justify-center">
    <h2 class="font-serif font-light text-[28px] md:text-[42px] text-[#FAFAF7] leading-[1.2] text-center mb-10">
      Let's create something together.
    </h2>
    <a
      href="mailto:ina.studio.creative@gmail.com"
      class="font-serif font-light text-[22px] md:text-[42px] text-[#FAFAF7] underline underline-offset-[8px] decoration-[0.5px]"
    >
      ina.studio.creative@gmail.com
    </a>
  </section>
</Layout>
