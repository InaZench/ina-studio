---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About — INA">
  <section class="bg-[#FAFAF7] px-6 md:px-10 pt-44 md:pt-56 pb-20 md:pb-28">
    <div class="max-w-[880px] mx-auto text-center">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-9">
        About
      </p>
      <h1 class="font-serif italic font-light text-[36px] md:text-[64px] text-[#0A0A0A] leading-[1.15] mb-9">
        Visual stories, crafted with AI.
      </h1>
      <p class="font-sans text-[15px] md:text-[16px] font-light text-[#555555] leading-relaxed max-w-[600px] mx-auto">
        INA Studio is a solo creative practice working across luxury, fashion,
        and product visual content — built entirely with AI tools.
      </p>
    </div>
  </section>

  <section class="bg-[#FAFAF7] px-6 md:px-10 pb-32 md:pb-44">
    <div class="max-w-[760px] mx-auto">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-5">
        Studio
      </p>
      <p class="font-serif font-light text-[18px] md:text-[22px] leading-[1.6] text-[#0A0A0A] mb-12">
        Based in Europe, working internationally. INA Studio explores how
        cinematic storytelling and AI-driven generation can come together to
        build brand worlds — from accessible luxury to performance-ready
        social content.
      </p>

      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-5">
        About this portfolio
      </p>
      <p class="font-serif font-light text-[18px] md:text-[22px] leading-[1.6] text-[#0A0A0A]">
        Every project shown here is an independent creative concept — a
        fictional universe built as a demonstration of AI visual
        storytelling.
      </p>
    </div>
  </section>

  <section class="bg-[#0A0A0A] px-6 md:px-10 py-28 md:py-32 min-h-[480px] flex flex-col items-center justify-center">
    <h2 class="font-serif font-light text-[28px] md:text-[42px] text-[#FAFAF7] leading-[1.2] text-center mb-10">
      Let's create something together.
    </h2>
    <a
      href="mailto:ina.studio.creative@gmail.com"
      class="font-serif font-light text-[22px] md:text-[42px] text-[#FAFAF7] underline underline-offset-[8px] decoration-[0.5px]"
    >
      ina.studio.creative@gmail.com
    </a>
  </section>
</Layout>
