---
import Layout from "../layouts/Layout.astro";

const approach = [
  {
    number: "01",
    title: "Concept first",
    text: "Every project starts with a clear narrative direction before any AI tool is opened.",
  },
  {
    number: "02",
    title: "AI as craft tool",
    text: "Soul, Seedance, and Nano Banana are not shortcuts — they are precision instruments used the way a director uses a camera.",
  },
  {
    number: "03",
    title: "Editorial finish",
    text: "Every frame is reviewed and refined for color, rhythm, and brand tone before delivery.",
  },
];

const stack = [
  {
    name: "Higgsfield Soul 2.0",
    desc: "Character and motion generation for cinematic protagonists and product talent.",
  },
  {
    name: "Seedance 2.0",
    desc: "High-fidelity video generation for hero films and atmospheric establishing shots.",
  },
  {
    name: "Nano Banana Pro",
    desc: "Editorial image generation for stills, product photography, and key art.",
  },
];

const formats = [
  {
    name: "Cinematic campaigns",
    desc: "Full hero films and brand-defining moments",
  },
  {
    name: "Product films",
    desc: "Detailed motion sequences focused on a single product",
  },
  {
    name: "Performance content",
    desc: "Short-form variations optimized for paid social",
  },
  {
    name: "Brand documentaries",
    desc: "Slow editorial pieces telling a brand's story",
  },
];
---

<Layout title="About — INA">
  <!-- INTRODUCTION -->
  <section class="bg-[#FAFAF7] px-6 md:px-10 pt-44 md:pt-56 pb-24 md:pb-32">
    <div class="max-w-[880px] mx-auto text-center">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-10">
        About the studio
      </p>
      <h1 class="font-serif font-light text-[36px] md:text-[64px] text-[#0A0A0A] leading-[1.15] mb-12">
        Working at the intersection<br />of cinema and AI craft.
      </h1>
      <p class="font-sans text-[15px] md:text-[16px] font-light text-[#555555] leading-relaxed max-w-[620px] mx-auto">
        INA is a solo studio creating cinematic visual content for European brands. The work spans luxury campaigns, product films, and performance-driven content — produced entirely with AI tools, refined through cinematic craft.
      </p>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="bg-[#F4F4F1] px-6 md:px-10 py-24 md:py-32">
    <div class="max-w-[1100px] mx-auto">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-12 md:mb-16 text-center">
        Approach
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-10">
        {approach.map((item) => (
          <div class="max-w-[280px] mx-auto md:mx-0">
            <p class="font-serif italic font-light text-[28px] text-[#0A0A0A]">{item.number}</p>
            <h3 class="font-serif text-[22px] text-[#0A0A0A] mt-4">{item.title}</h3>
            <p class="text-[13px] font-light leading-[1.85] text-[#555555] mt-4">
              {item.text}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STACK -->
  <section class="bg-[#FAFAF7] px-6 md:px-10 py-32 md:py-40">
    <div class="max-w-[1100px] mx-auto">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-4">
        Stack
      </p>
      <h2 class="font-serif font-light text-[28px] md:text-[38px] text-[#0A0A0A] mb-16 md:mb-20">
        Tools of the studio.
      </h2>
      <div>
        {stack.map((tool, i) => (
          <div class={`py-8 md:py-9 ${i !== 0 ? "border-t border-black/[0.08]" : ""}`}>
            <div class="flex flex-col md:flex-row md:items-baseline gap-3 md:gap-0">
              <div class="md:w-[40%]">
                <h3 class="font-serif text-[22px] md:text-[26px] text-[#0A0A0A]">{tool.name}</h3>
              </div>
              <div class="md:w-[60%]">
                <p class="text-[13px] md:text-[14px] font-light leading-[1.85] text-[#555555]">
                  {tool.desc}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FORMATS -->
  <section class="bg-[#F4F4F1] px-6 md:px-10 py-24 md:py-32">
    <div class="max-w-[880px] mx-auto">
      <p class="text-[10px] font-light tracking-[0.3em] text-[#999999] uppercase mb-8">
        What the studio does
      </p>
      <h2 class="font-serif italic font-light text-[28px] md:text-[38px] text-[#0A0A0A] mb-12">
        Formats.
      </h2>
      <div>
        {formats.map((fmt, i) => (
          <div class={`py-6 md:py-7 ${i !== 0 ? "border-t border-black/[0.08]" : ""}`}>
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
              <h3 class="font-serif text-[18px] md:text-[22px] text-[#0A0A0A]">{fmt.name}</h3>
              <p class="text-[12px] md:text-[13px] font-light text-[#888888] md:max-w-[360px]">
                {fmt.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT TEASER -->
  <section class="bg-[#0A0A0A] px-6 md:px-10 py-28 md:py-32 min-h-[480px] flex flex-col items-center justify-center">
    <h2 class="font-serif font-light text-[28px] md:text-[42px] text-[#FAFAF7] leading-[1.2] text-center mb-10">
      Let's create something together.
    </h2>
    <a
      href="mailto:ina.studio.creative@gmail.com"
      class="font-serif font-light text-[22px] md:text-[42px] text-[#FAFAF7] underline underline-offset-[8px] decoration-[0.5px]"
    >
      ina.studio.creative@gmail.com
    </a>
  </section>
</Layout>
